# Copy this file to `.env` and fill in real values. Do not commit `.env`.

# Get one at https://console.anthropic.com → "API Keys" → Create Key
# Format: starts with "sk-ant-..."
ANTHROPIC_API_KEY=

# Claude model to use across all three pipeline stages.
# claude-sonnet-4-6 is the MVP default per IMPLEMENTATION_PLAN.md.
CLAUDE_MODEL=claude-sonnet-4-6

# Allowed CORS origin for the Vite dev server.
FRONTEND_ORIGIN=http://localhost:5173
